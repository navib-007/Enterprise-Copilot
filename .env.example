APP_NAME=enterprise-ai-ops-copilot
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_ai_ops
POSTGRES_USER=enterprise_user
POSTGRES_PASSWORD=change_me

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_HTTPS=false

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY=replace_with_secure_private_key
JWT_PUBLIC_KEY=replace_with_secure_public_key
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
